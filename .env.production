# Production Environment Configuration for VPS Deployment
# Copy this file to .env on your VPS at /opt/postiz/.env

# =====================================
# REQUIRED SETTINGS - MUST CONFIGURE
# =====================================

# Your domain or VPS IP
MAIN_URL=http://your-vps-ip:4007
FRONTEND_URL=http://your-vps-ip:4007
NEXT_PUBLIC_BACKEND_URL=http://your-vps-ip:4007/api

# IMPORTANT: Generate a strong, random JWT secret (minimum 32 characters)
# You can generate one using: openssl rand -base64 48
JWT_SECRET=CHANGE-THIS-TO-A-LONG-RANDOM-STRING-MINIMUM-32-CHARACTERS

# Database connection (internal Docker network)
DATABASE_URL=postgresql://postiz-user:your-strong-db-password@postiz-postgres:5432/postiz-db

# Redis connection (internal Docker network)
REDIS_URL=redis://postiz-redis:6379

# Internal backend URL (DO NOT CHANGE unless you know what you're doing)
BACKEND_INTERNAL_URL=http://localhost:3000

# Temporal workflow engine (DO NOT CHANGE)
TEMPORAL_ADDRESS=temporal:7233

# General application settings
IS_GENERAL=true
DISABLE_REGISTRATION=false

# =====================================
# STORAGE SETTINGS
# =====================================

# Option 1: Local Storage (Simple, no external dependencies)
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Option 2: Cloudflare R2 Storage (Uncomment to use)
# STORAGE_PROVIDER=cloudflare
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_ACCESS_KEY=your-access-key
# CLOUDFLARE_SECRET_ACCESS_KEY=your-secret-access-key
# CLOUDFLARE_BUCKETNAME=your-bucket-name
# CLOUDFLARE_BUCKET_URL=https://your-bucket-url.r2.cloudflarestorage.com/
# CLOUDFLARE_REGION=auto

# =====================================
# DATABASE CREDENTIALS
# =====================================

POSTGRES_PASSWORD=your-strong-db-password
POSTGRES_USER=postiz-user
POSTGRES_DB=postiz-db

# Temporal database credentials
TEMPORAL_DB_PASSWORD=temporal-password
TEMPORAL_DB_USER=temporal

# =====================================
# PORT CONFIGURATION (Optional)
# =====================================

POSTIZ_PORT=4007
POSTGRES_PORT=5432
REDIS_PORT=6379
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# =====================================
# SOCIAL MEDIA INTEGRATIONS (Optional)
# =====================================
# Configure these only if you need social media integrations
# Get API keys from respective platform developer portals

# Twitter/X
X_API_KEY=
X_API_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Beehiiv
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Dribbble
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=

# Slack
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=

# Mastodon
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# =====================================
# PAYMENT / STRIPE SETTINGS (Optional)
# =====================================

FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=

# =====================================
# ADDITIONAL FEATURES (Optional)
# =====================================

# OpenAI for AI features
OPENAI_API_KEY=

# Discord support server link
NEXT_PUBLIC_DISCORD_SUPPORT=

# Polotno editor key
NEXT_PUBLIC_POLOTNO=

# API rate limit (requests per hour)
API_LIMIT=30

# Chrome Extension ID (for Skool and cookie-based integrations)
EXTENSION_ID=

# =====================================
# SHORT LINK SERVICES (Optional)
# =====================================

# Dub.co
# DUB_TOKEN=
# DUB_API_ENDPOINT=https://api.dub.co
# DUB_SHORT_LINK_DOMAIN=dub.sh

# Short.io
# SHORT_IO_SECRET_KEY=

# Kutt
# KUTT_API_KEY=
# KUTT_API_ENDPOINT=https://kutt.it/api/v2
# KUTT_SHORT_LINK_DOMAIN=kutt.it

# LinkDrip
# LINK_DRIP_API_KEY=
# LINK_DRIP_API_ENDPOINT=https://api.linkdrip.com/v1/
# LINK_DRIP_SHORT_LINK_DOMAIN=dripl.ink

# =====================================
# DEVELOPER SETTINGS (DO NOT CHANGE)
# =====================================

NX_ADD_PLUGINS=false

# =====================================
# EMAIL SETTINGS (Optional)
# =====================================
# Uncomment if you want to enable email verification

# RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM_ADDRESS=noreply@your-domain.com
# EMAIL_FROM_NAME=Postiz

# =====================================
# OAUTH SETTINGS (Optional - Advanced)
# =====================================
# For using external OAuth providers like Authentik

# NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME=Authentik
# NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL=https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png
# POSTIZ_GENERIC_OAUTH=false
# POSTIZ_OAUTH_URL=https://auth.example.com
# POSTIZ_OAUTH_AUTH_URL=https://auth.example.com/application/o/authorize
# POSTIZ_OAUTH_TOKEN_URL=https://auth.example.com/application/o/token
# POSTIZ_OAUTH_USERINFO_URL=https://auth.example.com/application/o/userinfo
# POSTIZ_OAUTH_CLIENT_ID=
# POSTIZ_OAUTH_CLIENT_SECRET=
# POSTIZ_OAUTH_SCOPE=openid profile email

# =====================================
# MONITORING / DEBUGGING (Optional)
# =====================================

# Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_SPOTLIGHT=1
